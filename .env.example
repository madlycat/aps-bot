# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=replace-me

# Optional: sync slash commands immediately to one development server.
# Omit this in production to register commands globally.
DISCORD_GUILD_ID=

# SQLite configuration survives restarts. The Docker Compose volume uses this path.
APS_DATABASE_PATH=data/aps.db

# Optional comma-separated channel IDs to enable on first startup only.
APS_BOOTSTRAP_CHANNEL_IDS=

# Name used for bot-owned webhooks.
APS_WEBHOOK_NAME=APS Relay

